---
interface Props {
  title?: string;
}

const { title = 'Admin — The Life' } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/admin', label: 'Dashboard', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6' },
  { href: '/admin/rooms', label: 'Rooms', icon: 'M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10' },
  { href: '/admin/tools', label: 'Tools', icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z' },
  { href: '/admin/comments', label: 'Comments', icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z' },
  { href: '/admin/personality', label: 'Personality', icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z' },
];
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@300;400;500;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="bg-void text-white font-sans min-h-screen antialiased">
    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <aside class="w-64 border-r border-white/5 bg-void/50 flex flex-col shrink-0">
        <div class="p-6 border-b border-white/5">
          <a href="/" class="flex items-center gap-3 group">
            <div class="w-3 h-3 rounded-full bg-alive animate-pulse shadow-glow-alive"></div>
            <span class="font-mono font-bold text-sm tracking-wider text-white group-hover:text-alive transition-colors">
              THE LIFE
            </span>
          </a>
          <p class="font-mono text-[10px] text-white/20 mt-2 uppercase tracking-[0.2em]">Admin Panel</p>
        </div>

        <nav class="flex-1 p-4 space-y-1">
          {navItems.map((item) => {
            const isActive = currentPath === item.href ||
              (item.href !== '/admin' && currentPath.startsWith(item.href));
            return (
              <a
                href={item.href}
                class:list={[
                  'flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-mono transition-all duration-200',
                  isActive
                    ? 'text-alive bg-alive/10 border border-alive/20'
                    : 'text-white/40 hover:text-white hover:bg-white/5 border border-transparent',
                ]}
              >
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
                </svg>
                {item.label}
              </a>
            );
          })}
        </nav>

        <div class="p-4 border-t border-white/5">
          <button
            id="logout-btn"
            class="w-full flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-mono text-white/30 hover:text-cost hover:bg-cost/5 transition-all border border-transparent hover:border-cost/20"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
            Logout
          </button>
        </div>
      </aside>

      <!-- Main content -->
      <main class="flex-1 overflow-auto">
        <div class="p-8">
          <slot />
        </div>
      </main>
    </div>

    <script>
      // Auth check on load
      const token = sessionStorage.getItem('thelife_admin_token');
      if (!token && !window.location.pathname.includes('/admin/login')) {
        window.location.href = '/admin/login';
      }

      // Logout
      document.getElementById('logout-btn')?.addEventListener('click', () => {
        sessionStorage.removeItem('thelife_admin_token');
        window.location.href = '/admin/login';
      });
    </script>
  </body>
</html>

<style is:global>
  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: #0a0a0f; }
  ::-webkit-scrollbar-thumb { background: #ffffff15; border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: #ffffff30; }
  ::selection { background: #00ff8833; color: #ffffff; }
</style>
