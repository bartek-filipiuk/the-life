---
import AdminLayout from '../../layouts/AdminLayout.astro';
import Dashboard from '../../components/admin/Dashboard';
---

<AdminLayout title="Dashboard — The Life Admin">
  <div class="space-y-8">
    <div>
      <h1 class="text-2xl font-bold text-white">Dashboard</h1>
      <p class="text-white/30 text-sm mt-1 font-mono">System overview and controls</p>
    </div>

    <!-- Quick Actions -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <button
        id="trigger-btn"
        class="p-4 bg-alive/5 border border-alive/20 rounded-lg text-left hover:bg-alive/10 transition-all group"
      >
        <div class="font-mono text-[10px] text-alive/60 uppercase tracking-wider mb-1">Manual Trigger</div>
        <div class="font-mono text-sm text-alive group-hover:text-alive">Run AI Cycle Now</div>
      </button>

      <button
        id="pause-btn"
        class="p-4 bg-cost/5 border border-cost/20 rounded-lg text-left hover:bg-cost/10 transition-all group"
      >
        <div class="font-mono text-[10px] text-cost/60 uppercase tracking-wider mb-1">Scheduler</div>
        <div class="font-mono text-sm text-cost group-hover:text-cost" id="scheduler-label">Pause/Resume</div>
      </button>

      <a
        href="/admin/rooms"
        class="p-4 bg-info/5 border border-info/20 rounded-lg text-left hover:bg-info/10 transition-all group block"
      >
        <div class="font-mono text-[10px] text-info/60 uppercase tracking-wider mb-1">Content</div>
        <div class="font-mono text-sm text-info group-hover:text-info">Manage Rooms</div>
      </a>
    </div>

    <!-- Config Overview -->
    <div class="bg-white/[0.02] border border-white/5 rounded-lg p-6">
      <h2 class="font-mono text-xs uppercase tracking-[0.2em] text-white/30 mb-4">Current Configuration</h2>
      <div id="config-grid" class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="space-y-1">
          <div class="font-mono text-[10px] text-white/20 uppercase">Model</div>
          <div class="font-mono text-sm text-white" id="cfg-model">-</div>
        </div>
        <div class="space-y-1">
          <div class="font-mono text-[10px] text-white/20 uppercase">Heartbeat</div>
          <div class="font-mono text-sm text-white" id="cfg-heartbeat">-</div>
        </div>
        <div class="space-y-1">
          <div class="font-mono text-[10px] text-white/20 uppercase">Budget/Day</div>
          <div class="font-mono text-sm text-cost" id="cfg-budget">-</div>
        </div>
        <div class="space-y-1">
          <div class="font-mono text-[10px] text-white/20 uppercase">Scheduler</div>
          <div class="font-mono text-sm" id="cfg-scheduler">-</div>
        </div>
        <div class="space-y-1">
          <div class="font-mono text-[10px] text-white/20 uppercase">Temperature</div>
          <div class="font-mono text-sm text-creative" id="cfg-temp">-</div>
        </div>
        <div class="space-y-1">
          <div class="font-mono text-[10px] text-white/20 uppercase">Novelty</div>
          <div class="font-mono text-sm text-info" id="cfg-novelty">-</div>
        </div>
        <div class="space-y-1">
          <div class="font-mono text-[10px] text-white/20 uppercase">Search</div>
          <div class="font-mono text-sm text-white" id="cfg-search">-</div>
        </div>
        <div class="space-y-1">
          <div class="font-mono text-[10px] text-white/20 uppercase">Meta Reflect</div>
          <div class="font-mono text-sm text-white" id="cfg-meta">-</div>
        </div>
      </div>
    </div>

    <!-- Full Dashboard -->
    <Dashboard client:load />

    <!-- Status message -->
    <div id="status-msg" class="hidden font-mono text-xs p-3 rounded-lg border"></div>
  </div>
</AdminLayout>

<script>
  const token = sessionStorage.getItem('thelife_admin_token');
  const baseUrl = (import.meta as unknown as { env: Record<string, string> }).env?.PUBLIC_API_URL ?? 'http://localhost:8765';

  const headers = {
    'Authorization': `Bearer ${token}`,
    'Accept': 'application/json',
    'Content-Type': 'application/json',
  };

  let schedulerRunning = false;

  function showStatus(msg: string, type: 'ok' | 'error') {
    const el = document.getElementById('status-msg')!;
    el.textContent = msg;
    el.className = `font-mono text-xs p-3 rounded-lg border ${
      type === 'ok'
        ? 'text-alive bg-alive/5 border-alive/20'
        : 'text-cost bg-cost/5 border-cost/20'
    }`;
  }

  async function loadConfig() {
    try {
      const resp = await fetch(`${baseUrl}/admin/config`, { headers });
      if (!resp.ok) return;
      const cfg = await resp.json();

      document.getElementById('cfg-model')!.textContent = cfg.model;
      document.getElementById('cfg-heartbeat')!.textContent = `${cfg.heartbeat_interval}s`;
      document.getElementById('cfg-budget')!.textContent = `$${cfg.budget_daily}/day`;
      document.getElementById('cfg-temp')!.textContent = `${cfg.temperature_min}-${cfg.temperature_max}`;
      document.getElementById('cfg-novelty')!.textContent = `${cfg.novelty_threshold}`;
      document.getElementById('cfg-search')!.textContent = cfg.search_provider;
      document.getElementById('cfg-meta')!.textContent = `every ${cfg.meta_reflection_every}`;

      schedulerRunning = cfg.scheduler_running;
      const schedulerEl = document.getElementById('cfg-scheduler')!;
      schedulerEl.textContent = schedulerRunning ? 'RUNNING' : 'PAUSED';
      schedulerEl.className = `font-mono text-sm ${schedulerRunning ? 'text-alive' : 'text-cost'}`;

      document.getElementById('scheduler-label')!.textContent = schedulerRunning ? 'Pause Scheduler' : 'Resume Scheduler';
    } catch {
      // Backend unreachable
    }
  }

  document.getElementById('trigger-btn')?.addEventListener('click', async () => {
    try {
      const resp = await fetch(`${baseUrl}/admin/trigger`, { method: 'POST', headers });
      const data = await resp.json();
      showStatus(
        data.status === 'ok' ? `Cycle complete! Room: ${data.room_id}` : `Error: ${data.message}`,
        data.status === 'ok' ? 'ok' : 'error',
      );
    } catch {
      showStatus('Failed to trigger cycle', 'error');
    }
  });

  document.getElementById('pause-btn')?.addEventListener('click', async () => {
    const action = schedulerRunning ? 'pause' : 'resume';
    try {
      const resp = await fetch(`${baseUrl}/admin/scheduler/${action}`, { method: 'POST', headers });
      const data = await resp.json();
      showStatus(data.message, 'ok');
      await loadConfig();
    } catch {
      showStatus(`Failed to ${action} scheduler`, 'error');
    }
  });

  loadConfig();
</script>
