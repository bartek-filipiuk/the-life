---
// No layout — standalone login page
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@300;400;500;700&display=swap"
      rel="stylesheet"
    />
    <title>Login — The Life Admin</title>
  </head>
  <body class="bg-void text-white font-sans min-h-screen flex items-center justify-center antialiased">
    <div class="w-full max-w-sm mx-auto px-6">
      <div class="text-center mb-8">
        <div class="w-4 h-4 rounded-full bg-alive animate-pulse shadow-glow-alive mx-auto mb-4"></div>
        <h1 class="font-mono font-bold text-xl tracking-wider">THE LIFE</h1>
        <p class="font-mono text-[10px] text-white/30 mt-2 uppercase tracking-[0.3em]">Admin Access</p>
      </div>

      <form id="login-form" class="space-y-4">
        <div>
          <label for="token" class="font-mono text-[10px] text-white/30 uppercase tracking-wider block mb-2">
            Admin Token
          </label>
          <input
            id="token"
            type="password"
            placeholder="Enter admin token..."
            autocomplete="current-password"
            class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-lg font-mono text-sm text-white placeholder-white/20 focus:outline-none focus:border-alive/50 focus:ring-1 focus:ring-alive/20 transition-all"
          />
        </div>

        <div id="error" class="hidden font-mono text-xs text-cost"></div>

        <button
          type="submit"
          id="submit-btn"
          class="w-full py-3 bg-alive/10 border border-alive/30 rounded-lg font-mono text-sm text-alive hover:bg-alive/20 transition-all uppercase tracking-wider"
        >
          Authenticate
        </button>
      </form>

      <div class="mt-8 text-center">
        <a href="/" class="font-mono text-[10px] text-white/20 hover:text-white/40 transition-colors uppercase tracking-wider">
          Back to site
        </a>
      </div>
    </div>

    <script>
      const form = document.getElementById('login-form') as HTMLFormElement;
      const input = document.getElementById('token') as HTMLInputElement;
      const error = document.getElementById('error') as HTMLDivElement;
      const btn = document.getElementById('submit-btn') as HTMLButtonElement;

      // If already logged in, redirect
      if (sessionStorage.getItem('thelife_admin_token')) {
        window.location.href = '/admin';
      }

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const token = input.value.trim();
        if (!token) return;

        btn.textContent = 'Verifying...';
        btn.disabled = true;
        error.classList.add('hidden');

        try {
          const baseUrl = (import.meta as unknown as { env: Record<string, string> }).env?.PUBLIC_API_URL ?? 'http://localhost:8765';
          const resp = await fetch(`${baseUrl}/admin/config`, {
            headers: {
              'Authorization': `Bearer ${token}`,
              'Accept': 'application/json',
            },
          });

          if (resp.ok) {
            sessionStorage.setItem('thelife_admin_token', token);
            window.location.href = '/admin';
          } else {
            error.textContent = 'Invalid token';
            error.classList.remove('hidden');
          }
        } catch {
          error.textContent = 'Cannot reach backend';
          error.classList.remove('hidden');
        } finally {
          btn.textContent = 'Authenticate';
          btn.disabled = false;
        }
      });
    </script>
  </body>
</html>
