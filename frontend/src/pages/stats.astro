---
import Layout from '../layouts/Layout.astro';
import StatsCharts from '../components/StatsCharts';
import { getStats, formatCost, formatNumber } from '../lib/api';

const stats = await getStats();

const costPerDay = stats?.cost_per_day ?? [];
const topTags = stats?.top_tags ?? [];
---

<Layout title="Stats — The Life">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Page Header -->
    <div class="space-y-4 mb-10">
      <h1 class="text-3xl font-bold text-white">Dashboard</h1>
      <p class="text-white/40 text-sm">
        Real-time statistics and cost transparency for the experiment.
      </p>
    </div>

    <!-- Key Metrics Grid -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4 mb-10">
      <!-- Total Cost -->
      <div class="rounded-lg border border-white/5 bg-white/[0.02] p-4 text-center">
        <p class="font-mono text-[10px] text-white/30 uppercase tracking-[0.15em]">Total Cost</p>
        <p class="font-mono text-xl font-bold text-cost mt-2">
          {stats ? formatCost(stats.total_cost) : '$0.00'}
        </p>
      </div>

      <!-- Total Tokens -->
      <div class="rounded-lg border border-white/5 bg-white/[0.02] p-4 text-center">
        <p class="font-mono text-[10px] text-white/30 uppercase tracking-[0.15em]">Tokens</p>
        <p class="font-mono text-xl font-bold text-info mt-2">
          {stats ? formatNumber(stats.total_tokens) : '0'}
        </p>
      </div>

      <!-- Total Rooms -->
      <div class="rounded-lg border border-white/5 bg-white/[0.02] p-4 text-center">
        <p class="font-mono text-[10px] text-white/30 uppercase tracking-[0.15em]">Rooms</p>
        <p class="font-mono text-xl font-bold text-white mt-2">
          {stats ? formatNumber(stats.total_rooms) : '0'}
        </p>
      </div>

      <!-- Avg Cost/Room -->
      <div class="rounded-lg border border-white/5 bg-white/[0.02] p-4 text-center">
        <p class="font-mono text-[10px] text-white/30 uppercase tracking-[0.15em]">Avg/Room</p>
        <p class="font-mono text-xl font-bold text-cost/70 mt-2">
          {stats ? formatCost(stats.avg_cost_per_room) : '$0.00'}
        </p>
      </div>

      <!-- Model -->
      <div class="rounded-lg border border-white/5 bg-white/[0.02] p-4 text-center">
        <p class="font-mono text-[10px] text-white/30 uppercase tracking-[0.15em]">Model</p>
        <p class="font-mono text-sm font-medium text-creative mt-2 truncate" title={stats?.model}>
          {stats?.model?.split('/').pop() ?? 'N/A'}
        </p>
      </div>

      <!-- Uptime -->
      <div class="rounded-lg border border-white/5 bg-white/[0.02] p-4 text-center">
        <p class="font-mono text-[10px] text-white/30 uppercase tracking-[0.15em]">Uptime</p>
        <p class="font-mono text-sm font-medium text-alive mt-2">
          {stats
            ? (() => {
                const uptimeSec = stats.uptime_seconds ?? (stats.uptime_days ?? 0) * 86400;
                const hours = Math.floor(uptimeSec / 3600);
                const days = Math.floor(hours / 24);
                return days > 0 ? `${days}d ${hours % 24}h` : `${hours}h`;
              })()
            : 'N/A'}
        </p>
      </div>
    </div>

    <!-- Charts -->
    <StatsCharts client:load costPerDay={costPerDay} topTags={topTags} />

    <!-- Cost Breakdown Table -->
    {costPerDay.length > 0 && (
      <div class="mt-10 rounded-lg border border-white/5 bg-white/[0.02] overflow-hidden">
        <div class="px-6 py-4 border-b border-white/5 bg-white/[0.02]">
          <h3 class="font-mono text-[10px] uppercase tracking-[0.3em] text-white/40">
            Daily Breakdown
          </h3>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="border-b border-white/5">
                <th class="text-left px-6 py-3 font-mono text-[10px] text-white/30 uppercase tracking-wider">Date</th>
                <th class="text-right px-6 py-3 font-mono text-[10px] text-white/30 uppercase tracking-wider">Rooms</th>
                <th class="text-right px-6 py-3 font-mono text-[10px] text-white/30 uppercase tracking-wider">Tokens</th>
                <th class="text-right px-6 py-3 font-mono text-[10px] text-white/30 uppercase tracking-wider">Cost</th>
              </tr>
            </thead>
            <tbody>
              {costPerDay.map((day) => (
                <tr class="border-b border-white/[0.03] hover:bg-white/[0.02] transition-colors">
                  <td class="px-6 py-3 font-mono text-sm text-white/50">{day.day}</td>
                  <td class="px-6 py-3 font-mono text-sm text-white/40 text-right">{day.rooms}</td>
                  <td class="px-6 py-3 font-mono text-sm text-info/60 text-right">{formatNumber(day.tokens)}</td>
                  <td class="px-6 py-3 font-mono text-sm text-cost/60 text-right">{formatCost(day.cost)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    )}
  </div>
</Layout>
