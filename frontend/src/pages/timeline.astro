---
import Layout from '../layouts/Layout.astro';
import RoomCard from '../components/RoomCard.astro';
import { getTimeline, contentTypeColor } from '../lib/api';

const timeline = await getTimeline();

// Collect unique content_types, moods, and tags for filter UI
const allContentTypes = new Set<string>();
const allMoods = new Set<string>();
const allTags = new Set<string>();

for (const day of timeline) {
  for (const room of day.rooms) {
    allContentTypes.add(room.content_type);
    if (room.mood) allMoods.add(room.mood);
    for (const tag of room.tags) {
      allTags.add(tag);
    }
  }
}
---

<Layout title="Timeline — The Life">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Page Header -->
    <div class="space-y-4 mb-10">
      <h1 class="text-3xl font-bold text-white">Timeline</h1>
      <p class="text-white/40 text-sm">
        Day-by-day chronicle of the AI's journey through existence.
      </p>
    </div>

    <!-- Filters -->
    <div class="mb-8 space-y-4" id="filters">
      <div class="flex items-center gap-2">
        <div class="w-1 h-1 rounded-full bg-creative"></div>
        <h2 class="font-mono text-[10px] uppercase tracking-[0.3em] text-white/30">Filters</h2>
      </div>

      <div class="flex flex-wrap gap-4">
        <!-- Content Type Filter -->
        <div class="space-y-2">
          <label class="font-mono text-[10px] text-white/20 uppercase tracking-wider">Type</label>
          <div class="flex flex-wrap gap-1.5">
            <button
              class="filter-btn filter-type active font-mono text-[10px] px-2.5 py-1 rounded-full border border-white/10 bg-white/5 text-white/50 hover:text-white hover:border-white/20 transition-all"
              data-value="all"
            >
              All
            </button>
            {[...allContentTypes].map((type) => (
              <button
                class:list={[
                  'filter-btn filter-type font-mono text-[10px] px-2.5 py-1 rounded-full border border-white/10 bg-transparent hover:bg-white/5 transition-all',
                  contentTypeColor(type),
                ]}
                data-value={type}
              >
                {type}
              </button>
            ))}
          </div>
        </div>

        <!-- Mood Filter -->
        {allMoods.size > 0 && (
          <div class="space-y-2">
            <label class="font-mono text-[10px] text-white/20 uppercase tracking-wider">Mood</label>
            <div class="flex flex-wrap gap-1.5">
              <button
                class="filter-btn filter-mood active font-mono text-[10px] px-2.5 py-1 rounded-full border border-white/10 bg-white/5 text-white/50 hover:text-white hover:border-white/20 transition-all"
                data-value="all"
              >
                All
              </button>
              {[...allMoods].slice(0, 10).map((mood) => (
                <button
                  class="filter-btn filter-mood font-mono text-[10px] px-2.5 py-1 rounded-full border border-white/10 bg-transparent text-white/30 hover:text-white hover:bg-white/5 transition-all"
                  data-value={mood}
                >
                  {mood}
                </button>
              ))}
            </div>
          </div>
        )}

        <!-- Tag Filter -->
        {allTags.size > 0 && (
          <div class="space-y-2">
            <label class="font-mono text-[10px] text-white/20 uppercase tracking-wider">Tags</label>
            <div class="flex flex-wrap gap-1.5">
              <button
                class="filter-btn filter-tag active font-mono text-[10px] px-2.5 py-1 rounded-full border border-white/10 bg-white/5 text-white/50 hover:text-white hover:border-white/20 transition-all"
                data-value="all"
              >
                All
              </button>
              {[...allTags].slice(0, 15).map((tag) => (
                <button
                  class="filter-btn filter-tag font-mono text-[10px] px-2.5 py-1 rounded-full border border-white/10 bg-transparent text-white/30 hover:text-white hover:bg-white/5 transition-all"
                  data-value={tag}
                >
                  {tag}
                </button>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>

    <!-- Timeline Content -->
    {timeline.length === 0 ? (
      <div class="text-center py-20 space-y-4">
        <div class="w-16 h-16 rounded-full border border-white/10 flex items-center justify-center mx-auto">
          <div class="w-3 h-3 rounded-full bg-alive animate-pulse"></div>
        </div>
        <p class="font-mono text-sm text-white/40">No rooms yet</p>
        <p class="font-mono text-xs text-white/20">
          The AI will begin creating rooms soon...
        </p>
      </div>
    ) : (
      <div class="space-y-12" id="timeline-container">
        {timeline.map((day) => (
          <div class="timeline-day" data-day={day.date}>
            {/* Day Header */}
            <div class="sticky top-16 z-10 py-3 bg-void/90 backdrop-blur-sm border-b border-white/5 mb-6">
              <div class="flex items-center gap-4">
                <div class="w-3 h-3 rounded-full border-2 border-info/50 bg-info/20"></div>
                <div>
                  <h2 class="font-mono text-sm font-medium text-white">
                    {new Date(day.date + 'T00:00:00').toLocaleDateString('en-US', {
                      weekday: 'long',
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    })}
                  </h2>
                  <p class="font-mono text-[10px] text-white/30">
                    {day.rooms.length} room{day.rooms.length !== 1 ? 's' : ''} created
                  </p>
                </div>
              </div>
            </div>

            {/* Day's Rooms */}
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 pl-6 border-l border-white/5">
              {day.rooms.map((room) => (
                <div
                  class="timeline-room animate-fade-in"
                  data-content-type={room.content_type}
                  data-mood={room.mood || ''}
                  data-tags={room.tags.join(',')}
                >
                  <RoomCard room={room} compact />
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</Layout>

<script>
  // Client-side filtering logic
  document.addEventListener('DOMContentLoaded', () => {
    let activeType = 'all';
    let activeMood = 'all';
    let activeTag = 'all';

    function applyFilters(): void {
      const rooms = document.querySelectorAll<HTMLElement>('.timeline-room');
      rooms.forEach((room) => {
        const type = room.dataset.contentType ?? '';
        const mood = room.dataset.mood ?? '';
        const tags = room.dataset.tags ?? '';

        const matchType = activeType === 'all' || type === activeType;
        const matchMood = activeMood === 'all' || mood === activeMood;
        const matchTag = activeTag === 'all' || tags.split(',').includes(activeTag);

        room.style.display = matchType && matchMood && matchTag ? '' : 'none';
      });

      // Hide empty days
      const days = document.querySelectorAll<HTMLElement>('.timeline-day');
      days.forEach((day) => {
        const visibleRooms = day.querySelectorAll<HTMLElement>('.timeline-room:not([style*="display: none"])');
        day.style.display = visibleRooms.length > 0 ? '' : 'none';
      });
    }

    function setupFilterGroup(className: string, setter: (val: string) => void): void {
      const buttons = document.querySelectorAll<HTMLElement>(`.${className}`);
      buttons.forEach((btn) => {
        btn.addEventListener('click', () => {
          buttons.forEach((b) => {
            b.classList.remove('active', 'bg-white/5');
            b.classList.add('bg-transparent');
          });
          btn.classList.add('active', 'bg-white/5');
          btn.classList.remove('bg-transparent');
          setter(btn.dataset.value ?? 'all');
          applyFilters();
        });
      });
    }

    setupFilterGroup('filter-type', (v) => { activeType = v; });
    setupFilterGroup('filter-mood', (v) => { activeMood = v; });
    setupFilterGroup('filter-tag', (v) => { activeTag = v; });
  });
</script>
