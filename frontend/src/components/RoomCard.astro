---
import type { Room } from '../lib/api';
import { assetUrl, contentTypeColor, formatCost } from '../lib/api';

interface Props {
  room: Room | null;
  compact?: boolean;
}

const { room, compact = false } = Astro.props;

const imageUrl = room ? assetUrl(room.image_url) : null;
const content = room?.content ?? '';
const excerpt = content.length > 200 ? content.slice(0, 200) + '...' : content;
---

{room ? (
  <article class:list={[
    'group rounded-lg border border-white/5 bg-white/[0.02] hover:bg-white/[0.04] transition-all duration-300',
    'hover:border-white/10 hover:shadow-lg',
    compact ? 'p-4' : 'p-6',
  ]}>
    <a href={`/room/${room.id}`} class="block space-y-4">
      {/* Image thumbnail */}
      {imageUrl && !compact && (
        <div class="relative aspect-video rounded-md overflow-hidden bg-white/5">
          <img
            src={imageUrl}
            alt={room.title}
            class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity duration-300"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-void/60 to-transparent"></div>
        </div>
      )}

      {/* Header */}
      <div class="space-y-2">
        <div class="flex items-center gap-2 flex-wrap">
          <span class:list={[
            'font-mono text-xs uppercase tracking-[0.2em] px-2 py-0.5 rounded-full border',
            contentTypeColor(room.content_type),
            `border-current/20 bg-current/5`,
          ]}>
            {room.content_type}
          </span>
          <span class="font-mono text-xs text-white/30">
            #{room.cycle_number}
          </span>
          {room.mood && (
            <span class="font-mono text-xs text-white/20">
              {room.mood}
            </span>
          )}
        </div>

        <h3 class:list={[
          'font-semibold text-white group-hover:text-alive transition-colors',
          compact ? 'text-sm' : 'text-lg',
        ]}>
          {room.title}
        </h3>

        {!compact && (
          <p class="text-sm text-white/40 leading-relaxed whitespace-pre-line">
            {excerpt}
          </p>
        )}
      </div>

      {/* Tags */}
      {room.tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5">
          {room.tags.slice(0, compact ? 3 : 6).map((tag) => (
            <span class="font-mono text-xs text-white/25 px-2 py-0.5 rounded bg-white/5">
              {tag}
            </span>
          ))}
          {room.tags.length > (compact ? 3 : 6) && (
            <span class="font-mono text-xs text-white/20">
              +{room.tags.length - (compact ? 3 : 6)}
            </span>
          )}
        </div>
      )}

      {/* Footer meta */}
      {!compact && (
        <div class="flex items-center gap-4 pt-2 border-t border-white/5 text-white/20">
          <span class="font-mono text-xs">
            Cost: <span class="text-cost">{formatCost(room.total_cost)}</span>
          </span>
          <span class="font-mono text-xs">
            {room.connections?.length ?? 0} connections
          </span>
          {(room.image_url || room.has_image) && (
            <span class="font-mono text-xs text-creative">IMG</span>
          )}
          {(room.music_url || room.has_music) && (
            <span class="font-mono text-xs text-alive">AUD</span>
          )}
        </div>
      )}
    </a>
  </article>
) : (
  <!-- Empty/placeholder state -->
  <div class="rounded-lg border border-dashed border-white/10 bg-white/[0.01] p-8 text-center">
    <div class="space-y-3">
      <div class="w-12 h-12 rounded-full border border-white/10 flex items-center justify-center mx-auto">
        <svg class="w-5 h-5 text-white/20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122" />
        </svg>
      </div>
      <p class="font-mono text-sm text-white/30">Click a node to explore</p>
      <p class="font-mono text-xs text-white/15">Select a room from the graph above</p>
    </div>
  </div>
)}
