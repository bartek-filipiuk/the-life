# The Life — Required Environment Variables
#
# Copy this file to .env and fill in your actual API keys.
# NEVER commit the .env file to version control.

# OpenRouter API key for LLM calls (https://openrouter.ai/)
THELIFE_OPENROUTER_API_KEY=your-openrouter-api-key-here

# Replicate API token for image/music generation (https://replicate.com/)
THELIFE_REPLICATE_API_TOKEN=your-replicate-api-token-here

# Brave Search API key for web search (https://brave.com/search/api/)
THELIFE_BRAVE_API_KEY=your-brave-api-key-here

# Tavily Search API key (https://tavily.com/) — alternative to Brave
THELIFE_TAVILY_API_KEY=your-tavily-api-key-here

# Search provider: "brave" or "tavily" (default: brave)
THELIFE_SEARCH_PROVIDER=brave
